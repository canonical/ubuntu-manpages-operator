# Ubuntu Manpages configuration.
# Copy this file to .env and adjust as needed.
# Values here override the real environment when .env is present.

# MANPAGES_SITE=https://manpages.ubuntu.com
# MANPAGES_ARCHIVE=https://archive.ubuntu.com/ubuntu
# MANPAGES_PUBLIC_HTML_DIR=/app/www
# MANPAGES_RELEASES=trusty, xenial, bionic, jammy, noble, plucky, questing
# MANPAGES_REPOS=main, restricted, universe, multiverse
# MANPAGES_ARCH=amd64
# MANPAGES_ADDR=:8080
# MANPAGES_LOG_LEVEL=info

# Discard the cache and force a full re-download and re-processing of all manpages.
# Use with caution, as this will be slow.
# MANPAGES_FORCE=false
